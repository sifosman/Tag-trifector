# ─── GreenFreightAcademy — Environment Variables ─────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Paystack ─────────────────────────────────────────────────────────────────
# Used for urgent CPD fee payments and programme enrolment payments
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key

# ─── Moodle ───────────────────────────────────────────────────────────────────
# Middleware API that sits between GFA frontend and Moodle
# Asif to build this middleware layer
MOODLE_API_URL=https://your-moodle-instance.com/webservice/rest/server.php
MOODLE_API_TOKEN=your-moodle-api-token
MOODLE_MIDDLEWARE_URL=https://your-middleware.vercel.app

# ─── Email (for enquiry notifications) ───────────────────────────────────────
# Supabase edge function handles email — configure in Supabase dashboard
# These are referenced here for documentation purposes
# RESEND_API_KEY=re_your-resend-api-key
# NOTIFICATION_EMAIL=admin@greenfreightacademy.co.za

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://greenfreightacademy.co.za
NEXT_PUBLIC_TAG_URL=https://transportactiongroup.co.za
NEXT_PUBLIC_BETTERDRIVER_URL=https://betterdriver.co.za
NEXT_PUBLIC_ZEROAFRICA_URL=https://zeroafrica.org

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "live" when real data is connected; "demo" shows mock data
NEXT_PUBLIC_DATA_SOURCE=demo
