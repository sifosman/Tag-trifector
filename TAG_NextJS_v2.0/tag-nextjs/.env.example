# ─── TAG Website — Environment Variables ─────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ─── Ecosystem URLs ───────────────────────────────────────────────────────────
# URLs for the companion platforms in the ecosystem
NEXT_PUBLIC_ZERO_AFRICA_URL=https://www.zeroafrica.org
NEXT_PUBLIC_GFA_URL=https://www.greenfreightacademy.com
NEXT_PUBLIC_BETTERDRIVER_URL=https://www.betterdriver.co.za

# ─── API Endpoints (Asif to configure) ───────────────────────────────────────
# Base URL for the TAG API layer
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# Enquiry form submission endpoint
# POST /api/submit-enquiry → EnquirySubmissionResult
ENQUIRY_API_URL=https://api.yourdomain.com/api/submit-enquiry

# Metrics endpoint (Academy Impact Strip)
# GET /api/metrics → TagMetrics
METRICS_API_URL=https://api.yourdomain.com/api/metrics

# Publications endpoint
# GET /api/publications → Publication[]
PUBLICATIONS_API_URL=https://api.yourdomain.com/api/publications

# Articles endpoint (Knowledge Hub)
# GET /api/articles → Article[]
ARTICLES_API_URL=https://api.yourdomain.com/api/articles

# Partners endpoint
# GET /api/partners → Partner[]
PARTNERS_API_URL=https://api.yourdomain.com/api/partners

# ─── Supabase (Asif to configure) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email notifications (Asif to configure) ─────────────────────────────────
# Used by the edge function that sends email on enquiry submission
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO_NOTIFY=your@email.com
